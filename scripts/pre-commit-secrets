#!/bin/bash
# Pre-commit hook to prevent secrets from being committed
#
# Installation:
#   chmod +x scripts/pre-commit-secrets
#   cp scripts/pre-commit-secrets .git/hooks/pre-commit
#
# Or with pre-commit framework:
#   pre-commit install

set -e

# Color codes
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Files to check (staged files)
files=$(git diff --cached --name-only --diff-filter=ACM)

# Track if any secrets found
found_secrets=0
secret_count=0

echo "🔐 Checking for secrets in staged files..."

# Patterns that indicate secrets
# These are intentionally broad to catch most cases
declare -a secret_patterns=(
    # AWS Keys
    'AKIA[0-9A-Z]{16}'                           # AWS Access Key

    # Private Keys
    'BEGIN RSA PRIVATE KEY'                       # RSA private key
    'BEGIN PRIVATE KEY'                           # Generic private key
    'BEGIN OPENSSH PRIVATE KEY'                   # OpenSSH private key
    'BEGIN CERTIFICATE'                           # Certificate
    '-----END.*PRIVATE KEY-----'                  # End of private key

    # Credentials in code
    'password\s*[:=]'                             # password = or password:
    'api_key\s*[:=]'                              # api_key = or api_key:
    'secret\s*[:=]'                               # secret = or secret:
    'token\s*[:=]'                                # token = or token:
    'credential\s*[:=]'                           # credential = or credential:

    # Environment variables with secrets
    'AWS_SECRET_ACCESS_KEY'                       # AWS secret
    'AWS_ACCESS_KEY_ID.*AKIA'                     # AWS key ID
    'GCLOUD.*PRIVATE_KEY'                         # GCP private key
    'AZURE.*ACCOUNT_KEY'                          # Azure key
    'GITHUB_TOKEN'                                # GitHub token
    'GITLAB_TOKEN'                                # GitLab token

    # Bearer tokens
    'authorization.*Bearer'                       # Bearer token
    'x-api-key'                                   # API key header

    # Database connections
    'mongodb://.*@'                               # MongoDB with credentials
    'postgresql://.*@'                            # PostgreSQL with credentials
    'mysql://.*@'                                 # MySQL with credentials
)

# Files to always ignore (can't contain secrets)
ignore_patterns=(
    '.git/'
    '.gitignore'
    '.gitattributes'
    '\.md$'
    '\.txt$'
    'LICENSE'
    'CHANGELOG'
)

should_ignore_file() {
    local file=$1
    for pattern in "${ignore_patterns[@]}"; do
        if [[ $file =~ $pattern ]]; then
            return 0  # Should ignore
        fi
    done
    return 1  # Should not ignore
}

# Check each file
for file in $files; do
    # Skip binary files
    if ! git ls-files --cached "$file" >/dev/null 2>&1; then
        continue
    fi

    # Skip ignored file types
    if should_ignore_file "$file"; then
        continue
    fi

    # Get the staged content
    content=$(git show ":$file" 2>/dev/null || cat "$file")

    # Check for secret patterns
    line_num=0
    while IFS= read -r line; do
        ((line_num++))

        for pattern in "${secret_patterns[@]}"; do
            # Case-insensitive matching
            if [[ $line =~ $pattern ]]; then
                # Exclude false positives
                if [[ $line =~ ^[[:space:]]*# ]] || [[ $line =~ example ]] || [[ $line =~ test ]] || [[ $line =~ mock ]]; then
                    continue
                fi

                echo -e "${RED}❌ Potential secret detected${NC}"
                echo -e "   File: ${YELLOW}$file${NC}"
                echo -e "   Line: ${YELLOW}$line_num${NC}"
                echo -e "   Pattern: ${YELLOW}$pattern${NC}"
                echo -e "   Content: ${RED}${line:0:60}...${NC}"
                echo

                found_secrets=1
                ((secret_count++))
            fi
        done
    done <<< "$content"
done

# Check for .cloudctl.yaml in staging (should never be committed)
if git diff --cached --name-only | grep -q '\.cloudctl\.yaml$'; then
    echo -e "${RED}❌ ERROR: .cloudctl.yaml is being committed!${NC}"
    echo -e "   ${YELLOW}.cloudctl.yaml is user configuration and should never be in git.${NC}"
    echo -e "   ${YELLOW}It should be in .gitignore.${NC}"
    found_secrets=1
fi

# Check for common secret filenames
secret_files=(
    '.env'
    '.env.local'
    '.env.*.local'
    '*.pem'
    '*.key'
    '*.pfx'
    'credentials.json'
    'secrets.yaml'
    'secrets.json'
    'id_rsa'
    'id_dsa'
)

for pattern in "${secret_files[@]}"; do
    if git diff --cached --name-only | grep -q "$pattern"; then
        echo -e "${RED}❌ ERROR: Potential secret file being committed${NC}"
        echo -e "   ${YELLOW}File pattern: $pattern${NC}"
        echo -e "   ${YELLOW}This file likely contains secrets and should not be committed.${NC}"
        found_secrets=1
    fi
done

echo

if [ $found_secrets -eq 1 ]; then
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}Pre-commit hook FAILED: Potential secrets detected ($secret_count)${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo
    echo -e "${YELLOW}What to do:${NC}"
    echo "  1. Review the matches above"
    echo "  2. Remove any credentials from your commit"
    echo "  3. Use environment variables instead"
    echo "  4. For local config, use .gitignore entries"
    echo "  5. Use .cloudctl.example.yaml as a template"
    echo
    echo -e "${YELLOW}If this is a false positive:${NC}"
    echo "  1. Mark the line with: # pragma: secret-ok"
    echo "  2. Or update this script to exclude it"
    echo
    echo -e "${YELLOW}To skip this check (not recommended):${NC}"
    echo "  git commit --no-verify"
    echo
    exit 1
else
    echo -e "${GREEN}✅ No secrets detected - safe to commit${NC}"
    exit 0
fi
